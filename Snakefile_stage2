FILTER_SPECS = {}
for _flag in ["solubility", "usability", "phopt", "topt", "tm"]:
    _val = config.get(f"filter_{_flag}", None)
    if _val is not None:
        FILTER_SPECS[_flag] = str(_val)

DO_FILTER = len(FILTER_SPECS) > 0

CLADES_K = config.get("clades", None)
if CLADES_K is not None:
    CLADES_K = int(CLADES_K)
    if CLADES_K < 1:
        raise ValueError(f"ERROR: -clades must be >= 1 (got {CLADES_K})")
DO_CLADES = CLADES_K is not None



def get_hit_pdbs(wildcards=None):
    """
    Called after the checkpoint resolves.  Returns list of PDB basenames
    whose EnzyMM TSV contained at least one data row.
    """
    ck = checkpoints.collect_enzymm_hits.get()
    with open(ck.output.hitlist) as fh:
        return [line.strip() for line in fh if line.strip()]


