def tree_clades_png_inputs(wildcards):
    inputs = {
        "tree":     "data/trees/nj_tree.nwk",
        "clades":   "data/clades/clade_assignments.tsv",
        "hit_list": "data/enzymm/hit_pdbs.txt",
    }
    if DO_FILTER:
        inputs["representatives"] = "predictions_output/clade_representatives.tsv"
    return inputs

rule tree_clades_png:
    input:
        unpack(tree_clades_png_inputs),
    output:
        png="data/trees/nj_tree_clades.png",
    log:
        "logs/tree_clades_png.log",
    params:
        rep_arg=lambda wildcards, input: (
            f"--representatives {input.representatives}" if DO_FILTER else ""
        ),
    conda:
        "envs/extract_sequences.yaml"
    shell:
        r"""
        python scripts/render_tree_png.py \
            {input.tree} {output.png} \
            --dpi 300 \
            --clades {input.clades} \
            --hit_list {input.hit_list} \
            {params.rep_arg} \
            2> {log}
        """

rule select_representatives:
    input:
        clades="data/clades/clade_assignments.tsv",
        filter_done="predictions_output/.filter_done",
        hit_list="data/enzymm/hit_pdbs.txt",
    output:
        tsv="predictions_output/clade_representatives.tsv",
    log:
        "logs/clades/select_representatives.log",
    params:
        spec_args=" ".join(
            f"--{flag} {val}" for flag, val in FILTER_SPECS.items()
        ),
    conda:
        "envs/extract_sequences.yaml"
    shell:
        r"""
        filtered=$(ls predictions_output/*_filtered.tsv 2>/dev/null || true)
        if [ -z "$filtered" ]; then
            echo -e "clade_id\tID\tscore\tn_eligible_in_clade\tn_members_in_clade" \
                > {output.tsv}
            echo "[INFO] No *_filtered.tsv found — wrote empty representatives TSV." \
                > {log}
        else
            python scripts/select_representatives.py \
                --clades {input.clades} \
                --hit_list {input.hit_list} \
                --filtered $filtered \
                --output {output.tsv} \
                {params.spec_args} \
                2> {log}
        fi
        """

